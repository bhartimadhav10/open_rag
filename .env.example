GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.1-8b-instant

EMBED_MODEL=BAAI/bge-small-en-v1.5
RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

DEVICE=auto            # auto | cuda | cpu
INDEX_DIR=./data/index
DOCS_DIR=./data/docs
SESSION_DB=./data/sessions.sqlite

TOP_K_ANN=20
TOP_K_RERANK=5
MAX_HISTORY_TURNS=6

# Cross-encoder reranking. true = better quality (~80ms retrieval),
# false = faster (~3-25ms retrieval), at the cost of slightly lower nDCG.
# Engine(rerank=True/False) overrides this at construction time.
RERANK_ENABLED=true

HOST=127.0.0.1
PORT=8000

# Comma-separated list of origins allowed to call the API from a browser.
# Empty = same-origin only. Set this when embedding the widget on your site:
#   CORS_ORIGINS=https://your-site.com,https://www.your-site.com
# Use "*" only for local dev — it's unsafe in production.
CORS_ORIGINS=
